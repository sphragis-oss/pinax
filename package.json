{
  "name": "pinax",
  "version": "0.1.5",
  "description": "Pinax: domain-agnostic, LLM-buildable dashboard framework for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "test": "node tests/run.mjs",
    "check:generic": "node scripts/check-generic.mjs",
    "check:api": "tsc --noEmit --strict --skipLibCheck --resolveJsonModule --esModuleInterop --target es2022 --module esnext --moduleResolution node --lib es2022,dom scripts/check-api-types.ts",
    "verify:criteria": "node scripts/verify-criteria.mjs",
    "lint": "eslint .",
    "lint:obsidian": "eslint --no-config-lookup --config eslint.obsidian.mjs src",
    "bench": "node scripts/bench.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "ajv": "^8.17.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.7.0",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "jsdom": "^29.1.1",
    "obsidian": "^1.13.1",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.62.1"
  }
}
